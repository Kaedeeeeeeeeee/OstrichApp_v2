{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "allowJs": false,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@/convex/*": ["./convex/*"]
    }
  },
  "include": ["convex/**/*.ts"],
  "exclude": ["node_modules", "convex/_generated", "ios", "shared/reference"]
}
