# macOS
.DS_Store
*.swp

# iOS / Xcode
# .xcodeproj 由 xcodegen 从 project.yml 生成，不进版本控制 (避免多 PR 改 project.yml 时 .pbxproj 冲突)
# 任何人 clone 后第一步: cd ios && xcodegen generate
ios/**/*.xcodeproj/
ios/**/*.xcworkspace/
ios/**/xcuserdata/
ios/**/*.xcuserstate
ios/**/DerivedData/
ios/**/build/
ios/**/Pods/
ios/**/.build/

# Convex
convex/_generated/
.env
.env.local
.env.*.local

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE
.vscode/
.idea/
*.iml

# Logs
*.log

# Secrets
*.p8
*.pem
